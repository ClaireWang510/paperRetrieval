# Database
DATABASE_URL=postgresql://localhost:5432/scientific_resource

# Embedding model (SentenceTransformer)
BGE_EMBEDDING_MODEL_PATH=
BGE_EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Reranker model
BGE_RERANKER_MODEL_PATH=
BGE_RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
BGE_RERANKER_BACKEND=hf_transformers
BGE_MODEL_CACHE_DIR=

# Generic LLM for figure semantics / semantic units / reasons / answer
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Optional dedicated intent decomposition LLM
INTENT_LLM_API_KEY=
INTENT_LLM_BASE_URL=
INTENT_LLM_MODEL=
